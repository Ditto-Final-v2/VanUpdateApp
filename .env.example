# Public MapLibre style. This is sent to the browser and must not contain a secret token.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron

# Phase 2: Supabase (leave blank for the local mock prototype)
NEXT_PUBLIC_SUPABASE_URL=
# Use the publishable key shown in Supabase project settings.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may expose an anon key instead. The app accepts either.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 2: server-only email and spam protection
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Canonical production URL, used for email links and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
